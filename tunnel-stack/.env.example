# Cloudflare Tunnel
# Get this from: Cloudflare Zero Trust > Networks > Tunnels > your tunnel > Configure
CLOUDFLARE_TUNNEL_TOKEN=

# Linkding
LINKDING_SUPERUSER=admin
LINKDING_PASSWORD=

# Immich database
IMMICH_DB_USER=immich
IMMICH_DB_PASSWORD=

# Path to NFS mount where Immich photos are stored
# Set up with: ~/docker/tunnel-stack/mount-nas.sh
IMMICH_PHOTOS_PATH=/mnt/nas/immich
