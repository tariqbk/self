# Copy this to secrets.env and fill in real values before running build-user-data.sh
# secrets.env is gitignored — never commit it.

# ── System ────────────────────────────────────────────────────────────────────
# Hashed password for the tariqbk user.
# Generate with: echo 'yourpassword' | openssl passwd -6 -stdin
USER_PASSWORD_HASH=

# ── Repo ──────────────────────────────────────────────────────────────────────
# Public GitHub repo URL (no trailing slash)
REPO_URL=https://github.com/YOUR_USERNAME/YOUR_REPO

# ── Network ───────────────────────────────────────────────────────────────────
# Static LAN IP for the Pi, configured directly on the Pi via network-config
# (netplan). Applies to both wlan0 and eth0 — only connect one at a time to
# avoid an IP conflict. Also used for Pi-hole's local DNS entries (*.home).
PI_LOCAL_IP=192.168.68.2
GATEWAY_IP=192.168.68.1

# WiFi credentials (used to generate network-config)
WIFI_SSID=
# Generate the WPA PSK from your plaintext password (avoids storing it in
# plaintext — the PSK is tied to the SSID above, regenerate if SSID changes):
#   python3 -c "import hashlib; print(hashlib.pbkdf2_hmac('sha1', b'YOUR_PASSWORD', b'YOUR_SSID', 4096, 32).hex())"
WIFI_PASSWORD=

# ── Portainer ─────────────────────────────────────────────────────────────────
# Must be at least 12 characters — Portainer CE rejects shorter admin passwords.
PORTAINER_PASSWORD=

# ── Pi-hole ───────────────────────────────────────────────────────────────────
PIHOLE_PASSWORD=

# ── Linkding ──────────────────────────────────────────────────────────────────
LINKDING_SUPERUSER=admin
LINKDING_PASSWORD=

# ── Immich ────────────────────────────────────────────────────────────────────
IMMICH_DB_USER=immich
IMMICH_DB_PASSWORD=
IMMICH_PHOTOS_PATH=/mnt/nas/immich

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
# Get from: Cloudflare Zero Trust > Networks > Tunnels > your tunnel > Configure
CLOUDFLARE_TUNNEL_TOKEN=

# ── NAS ───────────────────────────────────────────────────────────────────────
NAS_IP=192.168.68.X
